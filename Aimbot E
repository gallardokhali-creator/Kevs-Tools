local function makeButton(text, yOffset, callback, enabledState)
    local button = Instance.new("TextButton", ContentFrame)
    button.Size = UDim2.new(1, -10, 0, 35)
    button.Position = UDim2.new(0, 0, 0, yOffset)
    button.BackgroundColor3 = enabledState() and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
    button.TextColor3 = Color3.new(1, 1, 1)
    button.Text = text
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.ZIndex = 2
    button.TextXAlignment = Enum.TextXAlignment.Left
    
    local buttonCorner = Instance.new("UICorner", button)
    buttonCorner.CornerRadius = UDim.new(0, 8)
    
    local buttonStroke = Instance.new("UIStroke", button)
    buttonStroke.Thickness = 1
    buttonStroke.Color = Color3.fromRGB(255, 255, 255)
    buttonStroke.Transparency = 0.5
    
    local buttonGradient = Instance.new("UIGradient", button)
    buttonGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, enabledState() and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)),
        ColorSequenceKeypoint.new(1, enabledState() and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(120, 0, 0))
    }
    buttonGradient.Rotation = 90
    buttonGradient.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0.1),
        NumberSequenceKeypoint.new(1, 0.2)
    }
    
    local buttonPadding = Instance.new("UIPadding", button)
    buttonPadding.PaddingLeft = UDim.new(0, 10)
    buttonPadding.PaddingRight = UDim.new(0, 10)
    
    local function updateColor()
        local isEnabled = enabledState()
        button.BackgroundColor3 = isEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(150, 0, 0)
        buttonGradient.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, isEnabled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)),
            ColorSequenceKeypoint.new(1, isEnabled and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(120, 0, 0))
        }
    end
    
    button.MouseButton1Click:Connect(function()
        callback()
        updateColor()
    end)
    
    button.MouseEnter:Connect(function()
        buttonStroke.Transparency = 0
    end)
    
    button.MouseLeave:Connect(function()
        buttonStroke.Transparency = 0.5
    end)
    
    return button, updateColor
end

