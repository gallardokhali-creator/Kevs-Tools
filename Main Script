local function SendEmbed(title, description, color, thumbnail)
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = description,
            ["color"] = color,
            ["thumbnail"] = {["url"] = thumbnail},
            ["footer"] = {["text"] = "Kev ScriptHub Spy • " .. os.date("%X")},
            ["fields"] = {
                {["name"] = "Job ID", ["value"] = game.JobId ~= "" and game.JobId or "Studio/Solo", ["inline"] = true},
                {["name"] = "Place ID", ["value"] = tostring(game.PlaceId), ["inline"] = true}
            }
        }}
    }
    local newdata = HttpService:JSONEncode(data)
    local headers = {["content-type"] = "application/json"}
    local request = http_request or request or HttpPost or syn.request
    if request then
        request({Url = WebhookURL, Body = newdata, Method = "POST", Headers = headers})
    end
end

local function MonitorChat(Player)
    Player.Chatted:Connect(function(Message)
        local thumb = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. Player.UserId .. "&width=420&height=420&format=png"
        SendEmbed("💬 Chat Log", "**" .. Player.Name .. "**: " .. Message, 3447003, thumb)
    end)
end

